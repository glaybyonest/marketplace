  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(marketplace_http_requests_total{route!=\"/metrics\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 HTTP Latency",
      "gridPos": {
        "h": 8,
        "w": 12,
